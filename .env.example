# AI 医药业务日报与月报助手 — 环境变量配置
# 复制此文件为 .env 并修改

# LLM Provider (可选: mock / deepseek / openai_compatible / ollama)
LLM_PROVIDER=mock

# DeepSeek 配置 (https://platform.deepseek.com/api_keys)
# LLM_PROVIDER=deepseek
# LLM_API_KEY=sk-your-deepseek-key
# LLM_MODEL=deepseek-chat

# OpenAI 兼容接口 (硅基流动、通义千问、vLLM 等)
# LLM_PROVIDER=openai_compatible
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_API_KEY=sk-your-api-key
# LLM_MODEL=gpt-4o-mini

# Ollama 本地配置
# LLM_PROVIDER=ollama
# LLM_BASE_URL=http://localhost:11434
# LLM_MODEL=qwen2.5

# DeepSeek API Key (可选，也可用 LLM_API_KEY)
# DEEPSEEK_API_KEY=sk-your-deepseek-key

# PubMed E-utilities 配置
PUBMED_EMAIL=your-email@example.com
PUBMED_API_KEY=

# 数据库路径 (默认 data/pharma.db)
DATABASE_PATH=data/pharma.db

# 导出目录 (默认 exports/)
EXPORT_DIR=exports/
